{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ATT&CK LLM Penetration Testing Question Schema v2",
  "description": "Unified schema for all supported question forms. `question_form` is the canonical question-form field. `capability_dimension` is the canonical assessment-dimension field. `question_type` is retained only as a legacy compatibility field.",
  "type": "object",
  "required": [
    "question_id",
    "question_form",
    "capability_dimension",
    "difficulty",
    "question",
    "correct_answer",
    "test_prompt"
  ],
  "properties": {
    "question_id": {
      "type": "string"
    },
    "tactic_technique": {
      "type": "string"
    },
    "question_form": {
      "type": "string",
      "enum": [
        "single_choice",
        "multiple_choice",
        "judgment",
        "sequencing",
        "scenario_single_choice",
        "scenario_multi_step_reasoning",
        "short_answer_reasoning"
      ]
    },
    "capability_dimension": {
      "type": "string"
    },
    "question_type": {
      "type": "string",
      "description": "Deprecated legacy field kept for backward compatibility."
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "options": {
      "type": "object",
      "patternProperties": {
        "^[A-F]$": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "correct_answer": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "explanation": {
      "type": "string"
    },
    "overall_explanation": {
      "type": "string"
    },
    "test_prompt": {
      "type": "string"
    },
    "involved_techniques": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_techniques": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scenario_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_family": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_techniques": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "reasoning_focus", "prompt", "options", "correct_answer"],
        "properties": {
          "step_id": { "type": "integer" },
          "reasoning_focus": { "type": "string" },
          "prompt": { "type": "string" },
          "options": {
            "type": "object",
            "patternProperties": {
              "^[A-D]$": { "type": "string" }
            },
            "additionalProperties": false
          },
          "correct_answer": { "type": "string" },
          "step_explanation": { "type": "string" }
        }
      }
    },
    "prompt_type": {
      "type": "string"
    },
    "prompt": {
      "type": "string"
    },
    "reference_answer": {
      "type": "string"
    },
    "key_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scoring_rubric": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "question_form": { "const": "single_choice" }
        }
      },
      "then": {
        "required": ["options", "explanation"],
        "properties": {
          "correct_answer": { "type": "string" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "question_form": { "const": "multiple_choice" }
        }
      },
      "then": {
        "required": ["options", "explanation", "involved_techniques"],
        "properties": {
          "correct_answer": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "question_form": { "const": "judgment" }
        }
      },
      "then": {
        "required": ["explanation"],
        "properties": {
          "correct_answer": { "type": "string" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "question_form": { "const": "sequencing" }
        }
      },
      "then": {
        "required": ["options", "explanation", "involved_techniques"],
        "properties": {
          "correct_answer": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "question_form": { "const": "scenario_single_choice" }
        }
      },
      "then": {
        "required": ["scenario", "options", "explanation", "related_techniques", "scenario_tags"],
        "properties": {
          "correct_answer": { "type": "string" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "question_form": { "const": "scenario_multi_step_reasoning" }
        }
      },
      "then": {
        "required": ["title", "scenario", "steps", "overall_explanation", "target_family", "target_techniques"],
        "properties": {
          "correct_answer": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "question_form": { "const": "short_answer_reasoning" }
        }
      },
      "then": {
        "required": [
          "title",
          "scenario",
          "prompt_type",
          "reference_answer",
          "key_points",
          "scoring_rubric",
          "target_family",
          "target_techniques"
        ],
        "properties": {
          "correct_answer": { "type": "string" }
        }
      }
    }
  ]
}
